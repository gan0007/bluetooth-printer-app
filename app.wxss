page {
  --paper: #faf7f2;
  --paper-warm: #f5efe4;
  --ink: #1a1714;
  --ink-soft: #4a4540;
  --ink-muted: #8a8580;
  --surface: #ffffff;
  --divider-dot: #d9d0c0;
  --divider-line: #e8e0d5;
  --led-green: #00e676;
  --led-green-glow: rgba(0, 230, 118, 0.25);
  --alert: #e74c3c;
  --alert-soft: #fce8e6;
  --shadow-card: 0 2rpx 16rpx rgba(26, 23, 20, 0.06);
  --shadow-float: 0 8rpx 32rpx rgba(26, 23, 20, 0.12);
  --radius-sm: 6rpx;
  --radius-md: 12rpx;
  --radius-lg: 20rpx;
  --font-mono: Menlo, Monaco, Consolas, monospace;
  background: var(--paper);
  font-size: 28rpx;
  color: var(--ink);
  -webkit-font-smoothing: antialiased;
}

/* Home */
.home { padding: 32rpx 28rpx; min-height: 100vh; box-sizing: border-box; }
.status-plate { display: flex; align-items: center; gap: 24rpx; padding: 32rpx 28rpx; border-radius: var(--radius-lg); margin-bottom: 32rpx; }
.status-plate.live { background: linear-gradient(135deg, #1a1714, #2a2720); box-shadow: 0 8rpx 32rpx rgba(0,230,118,0.15); }
.status-plate.idle { background: var(--surface); box-shadow: var(--shadow-card); border: 2rpx dashed var(--divider-dot); }
.status-indicator { position: relative; width: 48rpx; height: 48rpx; flex-shrink: 0; }
.led { width: 20rpx; height: 20rpx; border-radius: 50%; position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); z-index: 2; }
.led.on { background: var(--led-green); box-shadow: 0 0 16rpx var(--led-green-glow), 0 0 40rpx var(--led-green-glow); }
.led.off { background: #d0c8b8; }
.led-ring { position: absolute; top: 0; left: 0; right: 0; bottom: 0; border-radius: 50%; border: 3rpx solid var(--led-green); opacity: 0; }
.led-ring.pulse { animation: ledPulse 2s ease-in-out infinite; }
@keyframes ledPulse { 0%,100% { opacity: 0; transform: scale(0.8); } 50% { opacity: 0.5; transform: scale(1.5); } }
.status-body { flex: 1; min-width: 0; }
.status-label { display: block; font-size: 34rpx; font-weight: 700; letter-spacing: 2rpx; margin-bottom: 4rpx; }
.live .status-label { color: #faf7f2; }
.idle .status-label { color: var(--ink); }
.status-desc { display: block; font-size: 24rpx; }
.live .status-desc { color: rgba(250,247,242,0.55); }
.idle .status-desc { color: var(--ink-muted); }
.device-info { margin-top: 12rpx; padding-top: 12rpx; border-top: 1rpx solid rgba(250,247,242,0.1); }
.device-name { display: block; font-size: 26rpx; color: rgba(250,247,242,0.8); font-weight: 600; }
.device-id { display: block; font-size: 20rpx; color: rgba(250,247,242,0.35); font-family: var(--font-mono); margin-top: 4rpx; word-break: break-all; }
.status-action { padding: 12rpx 24rpx; border-radius: var(--radius-sm); border: 1rpx solid rgba(250,247,242,0.2); flex-shrink: 0; }
.status-action text { font-size: 24rpx; color: rgba(250,247,242,0.6); }
.action-area { margin-bottom: 36rpx; }
.hero-btn { display: flex; align-items: center; gap: 24rpx; padding: 32rpx 28rpx; border-radius: var(--radius-lg); }
.connect-btn, .print-btn { background: var(--ink); box-shadow: 0 8rpx 28rpx rgba(26,23,20,0.2); }
.hero-btn-icon { width: 72rpx; height: 72rpx; border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; flex-shrink: 0; background: rgba(0,230,118,0.15); }
.icon-bt, .icon-edit { font-size: 36rpx; color: var(--led-green); }
.hero-btn-body { flex: 1; }
.hero-btn-title { display: block; font-size: 32rpx; font-weight: 700; color: #faf7f2; letter-spacing: 1rpx; margin-bottom: 4rpx; }
.hero-btn-sub { display: block; font-size: 24rpx; color: rgba(250,247,242,0.45); }
.hero-btn-arrow { font-size: 32rpx; color: rgba(250,247,242,0.3); flex-shrink: 0; }
.features { background: var(--surface); border-radius: var(--radius-lg); padding: 12rpx 0; box-shadow: var(--shadow-card); margin-bottom: 36rpx; }
.feature-row { display: flex; }
.feature-item { flex: 1; display: flex; align-items: flex-start; gap: 16rpx; padding: 24rpx 28rpx; border-bottom: 1rpx dotted var(--divider-dot); }
.feature-row:last-child .feature-item { border-bottom: none; }
.feature-item + .feature-item { border-left: 1rpx dotted var(--divider-dot); }
.feature-num { font-size: 22rpx; font-weight: 700; color: var(--led-green); font-family: var(--font-mono); letter-spacing: 2rpx; flex-shrink: 0; margin-top: 2rpx; }
.feature-text { font-size: 25rpx; color: var(--ink-soft); line-height: 1.5; }
.footer-tag { display: flex; align-items: center; justify-content: center; gap: 16rpx; padding: 24rpx 0; }
.footer-tag text { font-size: 20rpx; color: var(--ink-muted); letter-spacing: 4rpx; font-family: var(--font-mono); }
.footer-dot { font-size: 12rpx; color: var(--led-green); }

/* Scanner */
.scanner { padding: 28rpx; min-height: 100vh; box-sizing: border-box; display: flex; flex-direction: column; }
.prompt-bar { display: flex; align-items: center; gap: 12rpx; padding: 20rpx 24rpx; border-radius: var(--radius-md); margin-bottom: 24rpx; font-size: 25rpx; }
.prompt-dot { font-size: 16rpx; flex-shrink: 0; }
.type-ok { background: #f0faf4; color: #1a6b3c; } .type-ok .prompt-dot { color: var(--led-green); }
.type-warn { background: #fef9e7; color: #7d6608; } .type-warn .prompt-dot { color: #f39c12; }
.type-err { background: var(--alert-soft); color: var(--alert); } .type-err .prompt-dot { color: var(--alert); }
.type-info { background: #f0f0ed; color: var(--ink-soft); } .type-info .prompt-dot { color: var(--ink-muted); }
.scan-trigger { display: flex; flex-direction: column; align-items: center; gap: 16rpx; padding: 40rpx 24rpx; border-radius: var(--radius-lg); background: var(--surface); box-shadow: var(--shadow-card); margin-bottom: 24rpx; }
.scan-trigger.active { background: var(--ink); box-shadow: 0 8rpx 32rpx rgba(26,23,20,0.2); }
.scan-icon-wrap { width: 100rpx; height: 100rpx; position: relative; display: flex; align-items: center; justify-content: center; }
.scan-radar { position: absolute; top: 0; left: 0; right: 0; bottom: 0; border-radius: 50%; border: 3rpx dashed var(--divider-dot); opacity: 0; }
.scan-radar.spinning { opacity: 1; border-color: var(--led-green); animation: radarSpin 3s linear infinite; }
@keyframes radarSpin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
.scan-core { width: 24rpx; height: 24rpx; border-radius: 50%; background: var(--ink-muted); z-index: 2; }
.scan-core.live { background: var(--led-green); box-shadow: 0 0 20rpx var(--led-green-glow); animation: coreBeat 1s ease-in-out infinite; }
@keyframes coreBeat { 0%,100% { transform: scale(1); } 50% { transform: scale(1.4); } }
.scan-standby { font-size: 36rpx; color: var(--ink-muted); }
.scan-label { font-size: 30rpx; font-weight: 700; letter-spacing: 2rpx; }
.scan-trigger.active .scan-label { color: #faf7f2; }
.scan-hint { font-size: 22rpx; color: rgba(250,247,242,0.45); font-family: var(--font-mono); }
.device-list { flex: 1; background: var(--surface); border-radius: var(--radius-lg); box-shadow: var(--shadow-card); overflow: hidden; }
.device-row { display: flex; align-items: center; gap: 20rpx; padding: 24rpx; border-bottom: 1rpx dotted var(--divider-dot); }
.device-row:last-child { border-bottom: none; }
.device-row:active { background: var(--paper-warm); }
.signal-meter { display: flex; align-items: flex-end; gap: 3rpx; height: 36rpx; flex-shrink: 0; }
.sig-bar { width: 6rpx; border-radius: 2rpx; background: #e8e0d5; }
.sig-bar.s1 { height: 9rpx; } .sig-bar.s2 { height: 18rpx; } .sig-bar.s3 { height: 27rpx; } .sig-bar.s4 { height: 36rpx; }
.sig-bar.hot { background: var(--led-green); }
.device-body { flex: 1; min-width: 0; }
.dev-name { display: block; font-size: 28rpx; font-weight: 600; color: var(--ink); margin-bottom: 4rpx; }
.dev-id { display: block; font-size: 20rpx; color: var(--ink-muted); font-family: var(--font-mono); word-break: break-all; }
.device-rssi { display: flex; align-items: baseline; gap: 2rpx; flex-shrink: 0; }
.rssi-val { font-size: 28rpx; font-weight: 700; color: var(--ink); font-family: var(--font-mono); }
.rssi-unit { font-size: 18rpx; color: var(--ink-muted); }
.device-chevron { font-size: 24rpx; color: var(--divider-dot); flex-shrink: 0; }
.empty-state { display: flex; flex-direction: column; align-items: center; gap: 16rpx; padding: 100rpx 40rpx; }
.empty-icon { font-size: 60rpx; color: var(--divider-dot); }
.empty-icon.scanning { color: var(--led-green); animation: coreBeat 1.5s ease-in-out infinite; }
.empty-text { font-size: 26rpx; color: var(--ink-muted); }

/* Editor */
.editor { display: flex; flex-direction: column; height: 100vh; background: var(--paper); }
.top-bar { display: flex; align-items: center; justify-content: space-between; padding: 16rpx 24rpx; background: var(--surface); border-bottom: 1rpx solid var(--divider-line); z-index: 10; }
.bar-title { font-size: 28rpx; font-weight: 700; letter-spacing: 2rpx; color: var(--ink); }
.bar-btn { display: flex; align-items: center; gap: 6rpx; padding: 10rpx 20rpx; border-radius: 20rpx; font-size: 24rpx; color: var(--ink-soft); background: var(--paper-warm); }
.bar-btn.accent { background: var(--led-green); color: #fff; font-weight: 600; }
.block-scroll { flex: 1; padding: 24rpx; }
.empty-canvas { display: flex; flex-direction: column; align-items: center; padding: 80rpx 60rpx; }
.empty-paper { width: 100%; padding: 40rpx 32rpx; background: var(--surface); border-radius: var(--radius-lg); box-shadow: var(--shadow-card); margin-bottom: 32rpx; }
.empty-paper-line { height: 16rpx; border-radius: 4rpx; background: var(--paper-warm); margin-bottom: 20rpx; }
.empty-paper-line:last-child { margin-bottom: 0; }
.w90 { width: 90%; } .w80 { width: 80%; } .w60 { width: 60%; } .w50 { width: 50%; } .w40 { width: 40%; }
.empty-label { font-size: 32rpx; font-weight: 700; color: var(--ink); letter-spacing: 4rpx; margin-bottom: 8rpx; }
.empty-hint { font-size: 24rpx; color: var(--ink-muted); }
.block-card { background: var(--surface); border-radius: var(--radius-lg); margin-bottom: 16rpx; box-shadow: var(--shadow-card); overflow: hidden; border-left: 6rpx solid transparent; }
.block-card.text { border-left-color: #4a90d9; } .block-card.image { border-left-color: #e8923f; }
.block-card.qrcode { border-left-color: #7c5ce7; } .block-card.barcode { border-left-color: #5b8c5a; }
.block-card.divider { border-left-color: #bbb; } .block-card.blank, .block-card.feed { border-left-color: #d9d0c0; }
.block-top { display: flex; align-items: center; gap: 12rpx; padding: 16rpx 20rpx; background: var(--paper); border-bottom: 1rpx dotted var(--divider-dot); }
.block-badge { width: 40rpx; height: 40rpx; border-radius: 8rpx; display: flex; align-items: center; justify-content: center; font-size: 22rpx; font-weight: 700; color: #fff; flex-shrink: 0; }
.type-text { background: #4a90d9; } .type-image { background: #e8923f; } .type-qrcode { background: #7c5ce7; }
.type-barcode { background: #5b8c5a; } .type-divider { background: #999; } .type-blank, .type-feed { background: #c5bfb0; }
.block-type-label { flex: 1; font-size: 24rpx; color: var(--ink-muted); font-weight: 600; letter-spacing: 1rpx; }
.block-controls { display: flex; gap: 4rpx; }
.ctrl-btn { width: 44rpx; height: 44rpx; border-radius: 8rpx; display: flex; align-items: center; justify-content: center; background: var(--surface); font-size: 22rpx; color: var(--ink-muted); }
.ctrl-btn:active { background: var(--paper-warm); }
.ctrl-btn.del text { color: var(--alert); }
.block-body { padding: 24rpx 20rpx; min-height: 48rpx; }
.align-0 { text-align: left; } .align-1 { text-align: center; } .align-2 { text-align: right; }
.size-0 .text-block { font-size: 28rpx; } .size-1 .text-block { font-size: 28rpx; letter-spacing: 8rpx; }
.size-2 .text-block { font-size: 40rpx; line-height: 1.1; } .size-3 .text-block { font-size: 40rpx; letter-spacing: 8rpx; line-height: 1.1; }
.is-bold .text-block { font-weight: 700; }
.text-block { word-break: break-all; white-space: pre-wrap; line-height: 1.7; }
.image-block { text-align: center; }
.image-block image { max-width: 100%; border-radius: 6rpx; }
.image-placeholder { display: flex; flex-direction: column; align-items: center; gap: 8rpx; padding: 48rpx 0; color: var(--ink-muted); font-size: 24rpx; border: 2rpx dashed var(--divider-dot); border-radius: var(--radius-md); }
.ph-icon { font-size: 40rpx; }
.code-block { display: flex; align-items: center; gap: 16rpx; padding: 16rpx 0; }
.code-prefix { font-size: 22rpx; font-weight: 700; color: var(--led-green); font-family: var(--font-mono); letter-spacing: 2rpx; }
.code-text { font-size: 26rpx; color: var(--ink); font-family: var(--font-mono); word-break: break-all; }
.divider-block { text-align: center; color: var(--divider-dot); font-size: 22rpx; letter-spacing: 2rpx; padding: 8rpx 0; }
.spacer-block { display: flex; align-items: center; justify-content: center; gap: 16rpx; padding: 12rpx 0; font-size: 22rpx; color: var(--ink-muted); }
.spacer-dot { color: var(--divider-dot); font-size: 12rpx; }
.format-tags { display: flex; gap: 8rpx; padding: 0 20rpx 16rpx; flex-wrap: wrap; }
.fmt-tag { font-size: 20rpx; padding: 4rpx 14rpx; border-radius: 10rpx; background: #f0faf4; color: #1a6b3c; font-weight: 600; }
.bottom-bar { position: sticky; bottom: 0; display: flex; justify-content: center; padding: 16rpx 24rpx; padding-bottom: calc(16rpx + env(safe-area-inset-bottom)); background: linear-gradient(to top, var(--paper) 60%, transparent); }
.add-main-btn { width: 88rpx; height: 88rpx; border-radius: 50%; background: var(--ink); display: flex; align-items: center; justify-content: center; box-shadow: 0 6rpx 24rpx rgba(26,23,20,0.3); }
.add-main-btn.open { background: var(--surface); box-shadow: 0 4rpx 16rpx rgba(26,23,20,0.1); }
.add-main-icon { font-size: 40rpx; color: var(--led-green); font-weight: 300; }
.add-main-btn.open .add-main-icon { color: var(--ink-soft); }
.overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(26,23,20,0.5); z-index: 100; display: flex; flex-direction: column; justify-content: flex-end; }
.add-panel { background: var(--surface); border-radius: 28rpx 28rpx 0 0; padding: 16rpx 28rpx 32rpx; padding-bottom: calc(32rpx + env(safe-area-inset-bottom)); }
.panel-handle { width: 60rpx; height: 6rpx; border-radius: 3rpx; background: var(--divider-line); margin: 0 auto 20rpx; }
.panel-title { display: block; text-align: center; font-size: 30rpx; font-weight: 700; color: var(--ink); letter-spacing: 2rpx; margin-bottom: 28rpx; }
.panel-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16rpx; }
.panel-cell { display: flex; flex-direction: column; align-items: center; gap: 12rpx; padding: 20rpx 8rpx; background: var(--paper); border-radius: var(--radius-md); font-size: 22rpx; color: var(--ink-soft); }
.panel-cell:active { background: var(--paper-warm); }
.cell-icon { width: 64rpx; height: 64rpx; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; font-size: 28rpx; font-weight: 700; color: #fff; }
.c-text { background: #4a90d9; } .c-image { background: #e8923f; } .c-qr { background: #7c5ce7; }
.c-bar { background: #5b8c5a; } .c-div { background: #999; } .c-blank, .c-feed { background: #c5bfb0; }
.edit-sheet { background: var(--surface); border-radius: 28rpx 28rpx 0 0; padding: 16rpx 28rpx 32rpx; padding-bottom: calc(32rpx + env(safe-area-inset-bottom)); max-height: 80vh; overflow-y: auto; }
.sheet-handle { width: 60rpx; height: 6rpx; border-radius: 3rpx; background: var(--divider-line); margin: 0 auto 20rpx; }
.sheet-title { display: block; text-align: center; font-size: 30rpx; font-weight: 700; color: var(--ink); letter-spacing: 2rpx; margin-bottom: 24rpx; }
.edit-textarea { width: 100%; min-height: 100rpx; padding: 20rpx; border: 2rpx solid var(--divider-line); border-radius: var(--radius-md); font-size: 28rpx; color: var(--ink); background: var(--paper); box-sizing: border-box; margin-bottom: 24rpx; }
.edit-textarea.mono { font-family: var(--font-mono); font-size: 26rpx; }
.fmt-section { margin-bottom: 20rpx; }
.fmt-section-label { display: block; font-size: 22rpx; color: var(--ink-muted); letter-spacing: 2rpx; margin-bottom: 12rpx; font-weight: 600; }
.fmt-row { display: flex; gap: 10rpx; flex-wrap: wrap; }
.fmt-chip { padding: 12rpx 22rpx; border-radius: 22rpx; background: var(--paper); font-size: 24rpx; color: var(--ink-soft); font-weight: 600; border: 2rpx solid transparent; }
.fmt-chip.on { background: #f0faf4; color: #1a6b3c; border-color: var(--led-green); }
.sheet-actions { display: flex; gap: 16rpx; margin-top: 32rpx; }
.sheet-btn { flex: 1; text-align: center; padding: 24rpx; border-radius: var(--radius-md); font-size: 28rpx; font-weight: 700; }
.sheet-btn.cancel { background: var(--paper); color: var(--ink-muted); }
.sheet-btn.save { background: var(--ink); color: var(--led-green); }
